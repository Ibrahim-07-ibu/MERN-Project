{
  "name": "stock-market-backend",
  "version": "1.0.1",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "kill-port": "powershell -Command \"Stop-Process -Id (Get-NetTCPConnection -LocalPort 5000).OwningProcess -Force\"",
    "restart": "npm run kill-port && npm run dev"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.2"
  }
}
