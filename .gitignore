# Root .gitignore for MERN Project

# Dependencies
node_modules/
**/node_modules/

# Environment / Secrets
.env
**/.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
**/dist/
**/build/

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
**/logs/
